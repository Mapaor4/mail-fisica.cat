# Domain info
NEXT_PUBLIC_APEX_DOMAIN=example.com
NEXT_PUBLIC_SITE_URL=https://mail.example.com

# SMTP2GO Configuration
SMTP2GO_API_KEY=your_smtp2go_api_key

# Cloudflare API Configuration (for automatic DNS forwarding)
ALLOW_AUTO_REGISTER=TRUE
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id # For your domain
CLOUDFLARE_API_KEY=your_cloudflare_api_key # (Account Token; Zone DNS Edit; Include Specific Zone example.com)

# Organization Passphrase Protection (Server-side only - do not use NEXT_PUBLIC_ prefix)
ASK_PASSPHRASE=TRUE # Set to FALSE to disable passphrase requirement
PASSPHRASE=your_organization_passphrase # Shared secret for your organization
NEXT_PUBLIC_PASSPHRASE_HINT="Hint text for remembering the passphrase" # Client-side hint displayed on sign-up form

# Neon Database
NEON_AUTH_BASE_URL=https://your-neon-project.neonauth.c-3.eu-central-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=sFYTmdwOcjQjOWZ31mTusK6qp0ORadCEXPJuijODekk=
NEON_DATA_API_URL=https://your-neon-project.apirest.c-3.eu-central-1.aws.neon.tech/neondb/rest/v1
NEON_JWKS_URL=https://your-neon-project.neonauth.c-3.eu-central-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
# Connection string (also called Database URL)
NEON_DATABASE_URL='postgresql://neondb_owner:npg_lx9uM0SgKDis@your-neon-project-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# Branding (optional)
NEXT_PUBLIC_SHOW_LOGO=TRUE
NEXT_PUBLIC_ORGANIZATION_LOGO_SVG_PATH=branding/my-organization-logo.svg # Path inside the 'public/' directory